# Copy this file to .env and fill in your values.
# All variables are optional — defaults are suited for local development.

# Main URL used by clients to reach CryptPad (e.g. https://cryptpad.example.com)
# CRYPTPAD_HTTP_UNSAFE_ORIGIN=http://localhost:3000

# Sandbox URL (must be a different domain/subdomain in production)
# CRYPTPAD_HTTP_SAFE_ORIGIN=http://safe.localhost:3000

# Address the Node.js server binds to (0.0.0.0 to accept external connections)
# CRYPTPAD_HTTP_ADDRESS=0.0.0.0

# Custom protocol for Parsec CSP integration
# CRYPTPAD_CUSTOM_PROTOCOL=parsec-desktop:

# Limit worker processes (recommended: 2 on constrained cloud instances)
# CRYPTPAD_MAX_WORKERS=2
